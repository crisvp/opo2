# Database — app user (runtime)
DATABASE_URL=postgresql://opo_app:opo_app_password@localhost:5432/opo
# Database — admin user (migrations only)
DATABASE_ADMIN_URL=postgresql://opo_admin:postgres@localhost:5432/opo

# S3 / Object Storage (RustFS in dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=opo-documents

# Better Auth (generated by init.ts)
BETTER_AUTH_SECRET=

# ALTCHA (generated by init.ts)
ALTCHA_HMAC_KEY=

# API Key Encryption (generated by init.ts)
API_KEY_ENCRYPTION_SECRET=

# CORS — comma-separated allowed origins
TRUSTED_ORIGINS=http://localhost:5173

# Server
PORT=3000
NODE_ENV=development

# OpenRouter (optional — used as system key if set)
OPENROUTER_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# ClamAV
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# LibreOffice sidecar (internal Docker network in production)
LIBREOFFICE_SIDECAR_URL=http://localhost:4000
