{
  "name": "@opo/server",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "worker": "tsx watch --env-file=../../.env src/jobs/worker.ts",
    "build": "tsc --noEmit && vite build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "migrate": "tsx --env-file=../../.env src/migrations/run.ts",
    "seed": "tsx --env-file=../../.env src/migrations/seed-data.ts",
    "codegen": "kysely-codegen --url $DATABASE_ADMIN_URL --out-file src/db/types.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-presigned-post": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@better-auth/passkey": "^1.4.18",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@opo/shared": "workspace:*",
    "altcha-lib": "^1.0.0",
    "better-auth": "^1.0.0",
    "clamscan": "^2.1.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.0",
    "graphile-worker": "^0.16.0",
    "ioredis": "^5.4.0",
    "kysely": "^0.27.0",
    "nanoid": "^5.0.0",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
